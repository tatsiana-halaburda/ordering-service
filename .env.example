# Copy to .env (do not commit). Point INVENTORY_SERVICE_URL at a running Inventory API.

DB_USERNAME=
DB_PASSWORD=
DB_SERVER=tcp:YOURSERVER.database.windows.net
DB_DATABASE=YOURDB

INVENTORY_SERVICE_URL=http://localhost:8001

# Optional: overrides DB_* when set
# AZURE_SQL_CONNECTION_STRING=
# DB_ODBC_DRIVER=ODBC Driver 18 for SQL Server

# Practice 3 — Service Bus (send): same queue name as Inventory listen.
AZURE_SERVICEBUS_SEND_CONNECTION_STRING=
AZURE_SERVICEBUS_QUEUE_NAME=
